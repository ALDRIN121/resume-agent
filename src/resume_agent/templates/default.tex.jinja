%% Resume Agent — default.tex.jinja
%% Jinja2: double-paren for variables, paren-percent for blocks, paren-hash for comments
%% LaTeX special chars in user data should use the |le filter (e.g. some_var | le)
\documentclass[10pt,letterpaper]{article}

% ── Packages ──────────────────────────────────────────────────────────────────
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{lmodern}
\usepackage{microtype}
\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{xcolor}
\usepackage{tabularx}

% ── Page geometry ─────────────────────────────────────────────────────────────
\addtolength{\oddsidemargin}{-0.5in}
\addtolength{\evensidemargin}{-0.5in}
\addtolength{\textwidth}{1in}
\addtolength{\topmargin}{-0.5in}
\addtolength{\textheight}{1.0in}

\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

% ── Section formatting (small-caps with full-width rule) ─────────────────────
\titleformat{\section}{%
  \vspace{-10pt}\scshape\raggedright\large\bfseries
}{}{0em}{}[\color{black}\titlerule\vspace{-5pt}]

% ── Hyperlinks ────────────────────────────────────────────────────────────────
\definecolor{linkblue}{RGB}{0,0,180}
\hypersetup{colorlinks=true, urlcolor=linkblue, linkcolor=black}

% ══════════════════════════════════════════════════════════════════════════════
%  Resume layout commands — DO NOT modify; the generator depends on these.
%  These macros expand to itemize environments; balance Start/End pairs.
% ══════════════════════════════════════════════════════════════════════════════
\newcommand{\resumeItem}[1]{%
  \item\small{%
    {#1 \vspace{-2pt}}%
  }%
}

\newcommand{\resumeSubheading}[4]{%
  \vspace{-1pt}\item
  \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
    \textbf{#1} & #2 \\
    \textit{\small#3} & \textit{\small #4} \\
  \end{tabular*}\vspace{-5pt}%
}

\newcommand{\resumeProjectHeading}[2]{%
  \item
  \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
    \small#1 & #2 \\
  \end{tabular*}\vspace{-5pt}%
}

\newcommand{\resumeSubItem}[1]{\resumeItem{#1}\vspace{-4pt}}

\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}

\pagestyle{empty}

\begin{document}

% ══════════════════════════════════════════════════════════════════════════════
%  HEADER
% ══════════════════════════════════════════════════════════════════════════════
\begin{center}
  {\Huge \scshape (( personal.full_name | le ))} \\ \vspace{2pt}
  \small
  (% if personal.location %)(( personal.location | le )) $|$ (% endif %)%
  (% if personal.phone %)(( personal.phone | le )) $|$ (% endif %)%
  \href{mailto:(( personal.email | href ))}{(( personal.email | le ))}%
  (% if personal.linkedin %) $|$ \href{https://linkedin.com/in/(( personal.linkedin | href ))}{linkedin.com/in/(( personal.linkedin | le ))}(% endif %)%
  (% if personal.github %) $|$ \href{https://github.com/(( personal.github | href ))}{github.com/(( personal.github | le ))}(% endif %)%
  (% if personal.website %) $|$ \href{(( personal.website | href ))}{(( personal.website | le ))}(% endif %)
\end{center}

% ══════════════════════════════════════════════════════════════════════════════
%  SUMMARY
% ══════════════════════════════════════════════════════════════════════════════
(% if summary %)
\section{Professional Summary}
\small{(( summary | le ))}
(% endif %)

% ══════════════════════════════════════════════════════════════════════════════
%  TECHNICAL SKILLS
% ══════════════════════════════════════════════════════════════════════════════
(% if skills %)
\section{Technical Skills}
\begin{itemize}[leftmargin=0.15in, label={}]
  \small{\item{
  (% for category, items in skills.items() %)
   \textbf{(( category | le ))}{: (( items | join(', ') | le ))} \\
  (% endfor %)
  }}
\end{itemize}
(% endif %)

% ══════════════════════════════════════════════════════════════════════════════
%  PROFESSIONAL EXPERIENCE
% ══════════════════════════════════════════════════════════════════════════════
(% if experience %)
\section{Professional Experience}
\resumeSubHeadingListStart
(% for role in experience %)
  \resumeSubheading
    {(( role.company | le ))}{(% if role.location %)(( role.location | le ))(% endif %)}
    {(( role.title | le ))}{(( role.start | le )) -- (% if role.end %)(( role.end | le ))(% else %)Present(% endif %)}
  (% if role.bullets %)
  \resumeItemListStart
  (% for bullet in role.bullets %)
    \resumeItem{(( bullet | le ))}
  (% endfor %)
  \resumeItemListEnd
  (% endif %)
(% endfor %)
\resumeSubHeadingListEnd
(% endif %)

% ══════════════════════════════════════════════════════════════════════════════
%  FEATURED PROJECTS
% ══════════════════════════════════════════════════════════════════════════════
(% if projects %)
\section{Featured Projects}
\resumeSubHeadingListStart
(% for project in projects %)
  \resumeProjectHeading
    {\textbf{(( project.name | le ))}(% if project.tech %) $|$ \emph{(( project.tech | join(', ') | le ))}(% endif %)}{(% if project.url %)\href{(( project.url | href ))}{Link}(% endif %)}
  \resumeItemListStart
  (% if project.description %)
    \resumeItem{(( project.description | le ))}
  (% endif %)
  (% for bullet in project.bullets %)
    \resumeItem{(( bullet | le ))}
  (% endfor %)
  \resumeItemListEnd
(% endfor %)
\resumeSubHeadingListEnd
(% endif %)

% ══════════════════════════════════════════════════════════════════════════════
%  EDUCATION
% ══════════════════════════════════════════════════════════════════════════════
(% if education %)
\section{Education}
\resumeSubHeadingListStart
(% for edu in education %)
  \resumeSubheading
    {(( edu.institution | le ))}{(% if edu.graduation %)(( edu.graduation | le ))(% endif %)}
    {(( edu.degree | le ))(% if edu.field %), (( edu.field | le ))(% endif %)}{(% if edu.gpa %)GPA: (( edu.gpa | le ))(% endif %)}
  (% if edu.notes %)
  \resumeItemListStart
  (% for note in edu.notes %)
    \resumeItem{(( note | le ))}
  (% endfor %)
  \resumeItemListEnd
  (% endif %)
(% endfor %)
\resumeSubHeadingListEnd
(% endif %)

% ══════════════════════════════════════════════════════════════════════════════
%  CERTIFICATIONS
% ══════════════════════════════════════════════════════════════════════════════
(% if certifications %)
\section{Certifications}
\begin{itemize}[leftmargin=0.15in, label={}]
  \small{\item{
  (% for cert in certifications %)
   \textbf{(( cert.name | le ))}(% if cert.issuer %) --- (( cert.issuer | le ))(% endif %)(% if cert.date %) \emph{(( cert.date | le ))}(% endif %) \\
  (% endfor %)
  }}
\end{itemize}
(% endif %)

% ══════════════════════════════════════════════════════════════════════════════
%  PUBLICATIONS
% ══════════════════════════════════════════════════════════════════════════════
(% if publications %)
\section{Publications}
\resumeSubHeadingListStart
(% for pub in publications %)
  \resumeItem{(( pub | le ))}
(% endfor %)
\resumeSubHeadingListEnd
(% endif %)

\end{document}
