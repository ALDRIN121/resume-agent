# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Only the key for your chosen provider is required.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# NVIDIA_API_KEY=nvapi-...

# Ollama runs locally — no key needed, but base URL may differ:
OLLAMA_BASE_URL=http://localhost:11434

# NVIDIA NIM self-hosted endpoint (leave blank to use NVIDIA cloud):
# NVIDIA_BASE_URL=http://localhost:8000/v1


# ── Optional overrides (can also be set in ~/.resume_agent/config.yaml) ───────
# RESUME_AGENT_PROVIDER=anthropic
# RESUME_AGENT_MODEL__DEFAULT=meta/llama-3.1-70b-instruct
# RESUME_AGENT_MODEL__VISION=claude-opus-4-6
# RESUME_AGENT_RETRIES__GENERATOR_MAX=5
